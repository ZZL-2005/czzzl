### 4. Gate.io API 集成代码示例 (TypeScript)

以下代码片段展示了如何使用 Gate.io API 完成核心功能。假设您已安装 `axios` 和 `ws` 库。

```typescript
// 引入依赖
import axios from 'axios';
import WebSocket from 'ws';
import crypto from 'crypto';

// Gate.io API 配置
const API_KEY = 'YOUR_API_KEY';
const API_SECRET = 'YOUR_API_SECRET';
const BASE_URL = 'https://api.gateio.ws/api/v4';
const WS_URL = 'wss://ws.gateio.ws/v4';

// 辅助函数：生成签名 (用于私有API)
function generateSignature(method: string, url: string, queryString: string, body: string): string {
    const timestamp = Math.floor(Date.now() / 1000).toString();
    const payload = [method, url, queryString, body, timestamp].join('\n');
    const signature = crypto.createHmac('sha512', API_SECRET).update(payload).digest('hex');
    return { timestamp, signature };
}

// (a) 获取历史K线数据 (REST API)
async function getHistoricalKlines(symbol: string, interval: string, limit: number = 100) {
    const url = `${BASE_URL}/futures/usdt/candlesticks`;
    const params = { contract: symbol, interval: interval, limit: limit };
    try {
        const response = await axios.get(url, { params });
        // 返回数据格式: [ [timestamp, open, high, low, close, volume, ...], ... ]
        return response.data;
    } catch (error) {
        console.error('Error fetching historical data:', error);
        return null;
    }
}

// (b) 订阅实时价格 (WebSocket)
function subscribeToRealTimePrice(symbol: string) {
    const ws = new WebSocket(WS_URL);

    ws.on('open', () => {
        console.log('WebSocket connected');
        // 订阅永续合约的实时行情频道
        const subscribeMsg = {
            time: Math.floor(Date.now() / 1000),
            channel: 'futures.tickers',
            event: 'subscribe',
            payload: [symbol] // 例如: 'BTC_USDT'
        };
        ws.send(JSON.stringify(subscribeMsg));
    });

    ws.on('message', (data) => {
        const message = JSON.parse(data.toString());
        if (message.event === 'update' && message.channel === 'futures.tickers') {
            const ticker = message.result;
            console.log(`Real-time Price for ${ticker.contract}: Last = ${ticker.last}, Bid = ${ticker.highest_bid}, Ask = ${ticker.lowest_ask}`);
            // 在这里处理价格更新，例如更新全局变量或触发策略检查
        }
    });

    ws.on('error', (error) => {
        console.error('WebSocket error:', error);
    });

    ws.on('close', () => {
        console.log('WebSocket disconnected');
        // 实现自动重连逻辑
    });
}

// (c) 发送永续合约买入订单 (REST API - 私有)
async function placeBuyOrder(symbol: string, size: number, price: string, orderType: string = 'limit') {
    const url = '/futures/usdt/orders';
    const method = 'POST';
    const body = JSON.stringify({
        contract: symbol,
        size: size, // 正数为买入，负数为卖出
        price: price,
        tif: 'gtc', // Good till cancelled
        type: orderType // 'limit' 或 'market'
    });
    const queryString = '';
    const { timestamp, signature } = generateSignature(method, url, queryString, body);

    try {
        const response = await axios.post(`${BASE_URL}${url}`, body, {
            headers: {
                'KEY': API_KEY,
                'Timestamp': timestamp,
                'SIGN': signature,
                'Content-Type': 'application/json'
            }
        });
        console.log('Order placed successfully:', response.data);
        return response.data;
    } catch (error) {
        console.error('Error placing order:', error.response?.data || error.message);
        return null;
    }
}

// 使用示例
async function main() {
    // 获取BTC永续合约的15分钟K线
    const klines = await getHistoricalKlines('BTC_USDT', '15m', 200);
    console.log('Historical Klines:', klines?.slice(0, 2));

    // 订阅实时价格
    subscribeToRealTimePrice('BTC_USDT');

    // 模拟下单 (请谨慎使用，确保参数正确)
    // const order = await placeBuyOrder('BTC_USDT', 1, '30000', 'limit');
}

main();
```

